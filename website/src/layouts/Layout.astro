---
import { Image } from 'astro:assets';
import logo from '../assets/logo.svg';
import s3Icon from '../assets/s3.svg';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  /** Section name used to highlight the active top-nav tab. */
  active?: 'home' | 'download' | 'features' | 'docs' | 'screens';
}

const {
  title = 'ilyStream - Creator broadcast studio',
  description = 'ilyStream is a Windows broadcast studio for creators who want streaming, overlays, chat, TTS, audio routing, and smart-light automation in one place.',
  image = 'images/studio-settings-preview.png',
  active,
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${base}${path.replace(/^\/+/, '')}`;
const imageUrl = Astro.site ? new URL(withBase(image), Astro.site).toString() : withBase(image);
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url;

const repoUrl = 'https://github.com/ilydrw/ilyStream';
const latestVersion = '0.0.9';
const releaseUrl = `https://github.com/ilydrw/ilyStream/releases/tag/v${latestVersion}`;
const setupUrl = `https://github.com/ilydrw/ilyStream/releases/download/v${latestVersion}/ilyStream-Setup-${latestVersion}.exe`;

// Auto-detect the active tab from the URL when the prop isn't provided.
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const norm = path.replace(base.replace(/\/+$/, ''), '') || '/';
const detected: NonNullable<Props['active']> =
  norm === '/' ? 'home'
  : norm.startsWith('/docs') ? 'docs'
  : norm.startsWith('/download') ? 'download'
  : norm.startsWith('/features') ? 'features'
  : norm.startsWith('/screens') ? 'screens'
  : 'home';
const current = active ?? detected;

const navItems = [
  { id: 'home', label: 'Home', href: withBase('/') },
  { id: 'download', label: 'Download', href: withBase('download/') },
  { id: 'features', label: 'Features', href: withBase('features/') },
  { id: 'docs', label: 'Docs', href: withBase('docs/') },
  { id: 'screens', label: 'Screens', href: withBase('screens/') },
] as const;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    <link rel="icon" href={withBase('favicon.ico')} />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <link rel="preconnect" href="https://rsms.me" crossorigin />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0d11" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href={withBase('/')} aria-label="ilyStream home">
          <span class="brand__mark"><Image src={logo} alt="" width="34" height="34" loading="eager" /></span>
          <span class="brand__name">ilyStream</span>
          <span class="brand__pill">v{latestVersion}</span>
        </a>

        <nav class="nav" aria-label="Primary">
          <ul>
            {navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={['nav__link', { 'nav__link--active': current === item.id }]}
                  aria-current={current === item.id ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
            <li>
              <a class="nav__link nav__link--external" href={repoUrl} rel="noopener">
                GitHub
                <svg aria-hidden="true" viewBox="0 0 16 16" width="12" height="12"><path fill="currentColor" d="M5 3h7a1 1 0 0 1 1 1v7h-2V6.4l-6.3 6.3-1.4-1.4L9.6 5H5V3z"/></svg>
              </a>
            </li>
            <li>
              <a class="nav__cta" href={setupUrl}>Get Windows app</a>
            </li>
          </ul>
        </nav>

        <button class="nav__toggle" type="button" aria-expanded="false" aria-controls="mobile-nav" aria-label="Toggle navigation">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <div class="mobile-nav" id="mobile-nav" hidden>
        <ul>
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={['mobile-nav__link', { 'mobile-nav__link--active': current === item.id }]}
                aria-current={current === item.id ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
          <li><a class="mobile-nav__link" href={repoUrl} rel="noopener">GitHub</a></li>
          <li><a class="mobile-nav__link mobile-nav__link--cta" href={setupUrl}>Get Windows app</a></li>
        </ul>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="footer">
      <div class="footer__inner">
        <div class="footer__brand">
          <a class="brand" href={withBase('/')} aria-label="ilyStream home">
            <span class="brand__mark"><Image src={logo} alt="" width="30" height="30" loading="lazy" /></span>
            <span class="brand__name">ilyStream</span>
          </a>
          <p>A focused control room for live creators. Built on Electron, runs natively on Windows.</p>
        </div>

        <div class="footer__cols">
          <div class="footer__col">
            <h4>Product</h4>
            <ul>
              <li><a href={withBase('/')}>Home</a></li>
              <li><a href={withBase('download/')}>Download</a></li>
              <li><a href={withBase('features/')}>Features</a></li>
              <li><a href={withBase('screens/')}>Screens</a></li>
            </ul>
          </div>
          <div class="footer__col">
            <h4>Documentation</h4>
            <ul>
              <li><a href={withBase('docs/')}>All guides</a></li>
              <li><a href={withBase('docs/getting-started/')}>Getting started</a></li>
              <li><a href={withBase('docs/philips-hue/')}>Philips Hue</a></li>
              <li><a href={withBase('docs/obs/')}>OBS overlays</a></li>
            </ul>
          </div>
          <div class="footer__col">
            <h4>Project</h4>
            <ul>
              <li><a href={repoUrl} rel="noopener">GitHub repository</a></li>
              <li><a href={releaseUrl} rel="noopener">Latest release</a></li>
              <li><a href="https://github.com/ilydrw/ilystream-deskthing/releases" rel="noopener">DeskThing companion</a></li>
            </ul>
          </div>
        </div>
      </div>
      <div class="footer__base">
        <div class="footer__s3">
          <Image src={s3Icon} alt="" width="20" height="20" loading="lazy" />
          <span>&copy; 2026 Sovereign Systems &amp; Solutions (S3)</span>
        </div>
        <p>Made for creators who would rather be live than fighting their tools.</p>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const toggle = document.querySelector('.nav__toggle');
        const mobile = document.getElementById('mobile-nav');
        if (!toggle || !mobile) return;
        toggle.addEventListener('click', () => {
          const open = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', String(!open));
          if (open) {
            mobile.setAttribute('hidden', '');
          } else {
            mobile.removeAttribute('hidden');
          }
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #0a0c10;
    --bg-raised: #11141b;
    --bg-soft: #161a23;
    --bg-elev: #1a2030;
    --text: #f4f6fb;
    --muted: #aab3c2;
    --quiet: #768195;
    --line: rgba(255, 255, 255, 0.09);
    --line-strong: rgba(255, 255, 255, 0.18);
    --cyan: #25c7ff;
    --cyan-soft: #5bd8ff;
    --green: #24d18b;
    --amber: #f7b84b;
    --rose: #ff5c7a;
    --violet: #a783ff;
    --violet-soft: #c2a8ff;
    --grad-brand: linear-gradient(135deg, #25c7ff 0%, #a783ff 100%);
    --grad-rose: linear-gradient(135deg, #ff5c7a 0%, #a783ff 100%);
    --grad-warm: linear-gradient(135deg, #f7b84b 0%, #ff5c7a 100%);
    --grad-cool: linear-gradient(135deg, #24d18b 0%, #25c7ff 100%);
    --max: 1200px;
    --header-h: 68px;
    --shadow-card: 0 1px 0 rgba(255, 255, 255, 0.04) inset, 0 8px 28px rgba(0, 0, 0, 0.32);
    --shadow-cta: 0 8px 28px rgba(37, 199, 255, 0.28);
    --radius: 12px;
    --radius-sm: 8px;
    font-family:
      'Inter var', Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      'Segoe UI', sans-serif;
    font-feature-settings: 'cv11', 'ss01', 'ss03';
  }

  @supports (font-variation-settings: normal) {
    :root {
      font-family:
        'Inter var', Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
        'Segoe UI', sans-serif;
    }
  }

  * { box-sizing: border-box; }

  html {
    min-width: 320px;
    background: var(--bg);
    color: var(--text);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-width: 320px;
    background:
      radial-gradient(1200px 600px at 70% -10%, rgba(167, 131, 255, 0.10), transparent 60%),
      radial-gradient(900px 500px at 10% -5%, rgba(37, 199, 255, 0.10), transparent 55%),
      var(--bg);
    color: var(--text);
    line-height: 1.55;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    text-rendering: geometricPrecision;
  }

  h1, h2, h3, h4, p, ul, ol { margin: 0; }
  h1, h2, h3, h4 { line-height: 1.08; letter-spacing: -0.01em; text-wrap: balance; }
  h1 { letter-spacing: -0.025em; }
  p { text-wrap: pretty; }

  a {
    color: inherit;
    text-decoration: none;
    transition: color 120ms ease, background-color 120ms ease, border-color 120ms ease;
  }

  img { display: block; max-width: 100%; height: auto; }
  button, input { font: inherit; }
  ::selection { background: rgba(37, 199, 255, 0.32); }

  :focus-visible {
    outline: 2px solid var(--cyan);
    outline-offset: 2px;
    border-radius: 6px;
  }

  .skip-link {
    position: absolute;
    top: -40px;
    left: 12px;
    z-index: 1000;
    padding: 8px 14px;
    background: var(--cyan);
    color: #041017;
    border-radius: 6px;
    font-weight: 800;
  }
  .skip-link:focus { top: 12px; }

  /* Shared button system */
  .button {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 10px 18px;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    transition: transform 80ms ease, background-color 120ms ease, border-color 120ms ease, box-shadow 120ms ease;
  }
  .button:active { transform: translateY(1px); }
  .button--primary {
    background: var(--grad-brand);
    color: #04111a;
    box-shadow: var(--shadow-cta);
  }
  .button--primary:hover { filter: brightness(1.08); }
  .button--ghost {
    background: rgba(255, 255, 255, 0.04);
    border-color: var(--line);
    color: var(--text);
  }
  .button--ghost:hover {
    border-color: var(--line-strong);
    background: rgba(255, 255, 255, 0.08);
  }
  .button--solid {
    background: var(--text);
    color: #04111a;
  }
  .button--solid:hover { background: #fff; }

  .eyebrow {
    color: var(--cyan);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .container {
    width: min(100% - 32px, var(--max));
    margin: 0 auto;
  }
</style>

<style>
  /* Header */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: saturate(160%) blur(14px);
    -webkit-backdrop-filter: saturate(160%) blur(14px);
    background: rgba(10, 12, 16, 0.72);
    border-bottom: 1px solid var(--line);
  }

  .site-header__inner {
    width: min(100% - 32px, var(--max));
    margin: 0 auto;
    height: var(--header-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    font-size: 1rem;
    color: var(--text);
  }

  .brand__mark {
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    background: var(--grad-brand);
    border-radius: 9px;
    box-shadow: 0 4px 18px rgba(167, 131, 255, 0.28);
  }
  .brand__mark img { border-radius: 6px; }

  .brand__pill {
    margin-left: 4px;
    padding: 3px 8px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .nav ul {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0;
    list-style: none;
  }

  .nav__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border-radius: 8px;
    color: var(--muted);
    font-weight: 600;
    font-size: 0.92rem;
  }

  .nav__link:hover {
    color: var(--text);
    background: rgba(255, 255, 255, 0.05);
  }

  .nav__link--active {
    color: var(--text);
    background: rgba(37, 199, 255, 0.1);
    box-shadow: inset 0 0 0 1px rgba(37, 199, 255, 0.28);
  }

  .nav__link--external svg {
    opacity: 0.7;
  }

  .nav__cta {
    margin-left: 8px;
    padding: 9px 14px;
    background: var(--grad-brand);
    color: #04111a;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.92rem;
    box-shadow: 0 4px 18px rgba(37, 199, 255, 0.28);
  }
  .nav__cta:hover { filter: brightness(1.08); }

  .nav__toggle {
    display: none;
    width: 44px;
    height: 44px;
    padding: 0;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--text);
    cursor: pointer;
  }
  .nav__toggle span {
    display: block;
    width: 18px;
    height: 2px;
    margin: 4px auto;
    background: currentColor;
    border-radius: 2px;
  }

  .mobile-nav {
    border-top: 1px solid var(--line);
    background: rgba(10, 12, 16, 0.96);
  }
  .mobile-nav ul {
    width: min(100% - 32px, var(--max));
    margin: 0 auto;
    padding: 12px 0;
    list-style: none;
    display: grid;
    gap: 4px;
  }
  .mobile-nav__link {
    display: block;
    padding: 12px 14px;
    color: var(--muted);
    font-weight: 600;
    border-radius: 8px;
  }
  .mobile-nav__link:hover { color: var(--text); background: rgba(255, 255, 255, 0.05); }
  .mobile-nav__link--active {
    color: var(--text);
    background: rgba(37, 199, 255, 0.1);
    box-shadow: inset 0 0 0 1px rgba(37, 199, 255, 0.28);
  }
  .mobile-nav__link--cta {
    margin-top: 6px;
    background: var(--grad-brand);
    color: #04111a;
    text-align: center;
  }
  .mobile-nav__link--cta:hover { filter: brightness(1.08); background: var(--grad-brand); }

  /* Footer */
  .footer {
    margin-top: 96px;
    border-top: 1px solid var(--line);
    background: #060810;
  }

  .footer__inner {
    width: min(100% - 32px, var(--max));
    margin: 0 auto;
    padding: 56px 0 32px;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 2fr);
    gap: 48px;
  }

  .footer__brand p {
    margin-top: 16px;
    color: var(--muted);
    max-width: 36ch;
  }

  .footer__cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .footer__col h4 {
    color: var(--text);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .footer__col ul {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 10px;
  }

  .footer__col a {
    color: var(--muted);
    font-size: 0.95rem;
  }
  .footer__col a:hover { color: var(--text); }

  .footer__base {
    width: min(100% - 32px, var(--max));
    margin: 0 auto;
    padding: 22px 0 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border-top: 1px solid var(--line);
    color: var(--quiet);
    font-size: 0.86rem;
  }
  .footer__base p { color: var(--quiet); }

  .footer__s3 {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  @media (max-width: 900px) {
    .nav { display: none; }
    .nav__toggle { display: inline-flex; align-items: center; justify-content: center; flex-direction: column; }
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 40px 0 24px;
    }
    .footer__cols { grid-template-columns: 1fr 1fr; }
    .footer__base {
      flex-direction: column;
      align-items: flex-start;
      padding: 18px 0 28px;
    }
  }

  @media (max-width: 540px) {
    .brand__pill { display: none; }
    .footer__cols { grid-template-columns: 1fr; }
  }
</style>
